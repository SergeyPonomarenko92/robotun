# Robotun API — local dev config. Copy to .env and edit if needed.

NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Postgres — docker-compose maps to host 5433 to avoid clashing with system pg.
DATABASE_URL=postgres://robotun:robotun_dev@localhost:55432/robotun

# Redis (sessions cache, rate limits, future SSE pub/sub).
REDIS_URL=redis://localhost:6380

# S3-compatible object storage (MinIO locally; AWS S3 in prod).
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=robotun
S3_SECRET_ACCESS_KEY=robotun_dev_minio
S3_BUCKET_QUARANTINE=robotun-quarantine
S3_BUCKET_PUBLIC=robotun-public
S3_BUCKET_KYC=robotun-kyc-private

# Auth (Module 1).
# Generate with: openssl genpkey -algorithm RSA -out api/keys/jwt-private.pem -pkeyopt rsa_keygen_bits:2048
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ISSUER=robotun
JWT_AUDIENCE=robotun-clients
ACCESS_TOKEN_TTL_SECONDS=900       # 15 min
REFRESH_TOKEN_TTL_SECONDS=2592000  # 30 days

# CORS — comma-separated origins allowed from the FE (Next.js dev).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Web Push VAPID keys (Module 9 push channel). Generate with:
#   npx web-push generate-vapid-keys --json
# Public key is also exposed via /api/v1/push/vapid-public-key so the FE
# service worker can subscribe without hard-coding it.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@robotun.dev

# SMTP (Module 9 email channel). Dev: mailpit at 11025. Prod: real SMTP.
SMTP_HOST=127.0.0.1
SMTP_PORT=11025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Robotun <noreply@robotun.dev>
BRAND_URL=http://localhost:3000

# ClamAV (Module 6 scan worker).
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=30000
